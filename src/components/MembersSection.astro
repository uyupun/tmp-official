---
// メンバーセクションコンポーネント
import MemberCard from "./MemberCard.astro";
---

<div class="mt-12 w-full max-w-2xl md:max-w-lg lg:max-w-2xl">
  <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-center mb-6 section-title">MEMBERS</h2>
  <div class="w-fit md:w-full mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2 md:gap-1 lg:gap-2">
    <MemberCard
      name="Takashi"
      roles={["Frontend Engineer", "UX Designer"]}
      imageUrl="/members/takashi.webp"
      websiteUrl="https://takashimelon.com/"
      alt="Takashi"
    />

    <MemberCard
      name="Kakky"
      roles={["Hardware Engineer", "Backend Engineer", "Agitator"]}
    />

    <MemberCard
      name="Kazukichi"
      roles={["Software Engineer", "Visual Designer", "Creative Director"]}
      imageUrl="/members/kazukichi.png"
      websiteUrl="https://tyokinuhata.github.io/"
      alt="Kazukichi"
    />

    <MemberCard
      name="Daisuke"
      roles={["Backend Engineer", "Props Designer"]}
    />

    <MemberCard
      name="Tatsuo"
      roles={["Construction Worker"]}
    />
  </div>
</div>

<style>
  .section-title {
    font-family: "Pirata One", cursive;
    -webkit-text-stroke: 2px white;
    paint-order: stroke fill;
  }
</style>
