---
// メンバーカードコンポーネント
export interface Props {
  name: string;
  roles: string[];
  imageUrl?: string;
  websiteUrl?: string;
  alt?: string;
}

const { name, roles, imageUrl, websiteUrl, alt } = Astro.props;
---

<div class="bg-black/50 backdrop-blur-sm p-5 text-white">
  <div class="flex flex-col items-center text-center">
    {websiteUrl ? (
      <a href={websiteUrl} target="_blank" rel="noopener noreferrer"
         class="w-14 h-14 rounded-full mb-3 overflow-hidden hover:opacity-80 transition-opacity">
        {imageUrl ? (
          <img src={imageUrl} alt={alt || name} class="w-full h-full object-cover">
        ) : (
          <div class="w-14 h-14 bg-white/20 rounded-full flex items-center justify-center">
            <span class="text-xl font-bold">{name.charAt(0)}</span>
          </div>
        )}
      </a>
    ) : (
      <div class="w-14 h-14 mb-3">
        {imageUrl ? (
          <img src={imageUrl} alt={alt || name} class="w-full h-full object-cover rounded-full">
        ) : (
          <div class="w-14 h-14 bg-white/20 rounded-full flex items-center justify-center">
            <span class="text-xl font-bold">{name.charAt(0)}</span>
          </div>
        )}
      </div>
    )}
    <h3 class="text-lg font-bold mb-2">{name}</h3>
    <p class="text-sm text-white/70">
      {roles.map((role, index) => (
        <>
          {role}{index < roles.length - 1 && <br />}
        </>
      ))}
    </p>
  </div>
</div>
